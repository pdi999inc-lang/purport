# ---- PurPort environment ----
# Copy to .env for local dev. On Railway, set these in the service "Variables" tab.

# Anthropic API key — powers the screenshot product-ID + condition vision step.
# Get one at https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Vision model. Set to a model your Anthropic account can access.
ANTHROPIC_MODEL=claude-sonnet-5

# Nimble API key — powers the live new/used price lookup.
# From your Nimble dashboard (https://nimbleway.com/) -> API credentials.
NIMBLE_API_KEY=your-nimble-token

# Nimble search endpoint. CONFIRM THIS against your Nimble dashboard/docs —
# accounts differ. The code posts a SERP-style search here.
NIMBLE_API_URL=https://api.webit.live/api/v1/realtime/serp

# Port is provided by Railway automatically; default for local dev.
PORT=3000
